<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="297.0" prefWidth="310.0" spacing="10" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com" xmlns:fx="http://javafx.com" fx:controller="org.example.calculator.HelloController">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <TextField fx:id="display" editable="false" prefHeight="47.0" prefWidth="226.0" style="-fx-font-size: 20px;">
    <font>
         <Font size="1.0" />
      </font></TextField>

    <GridPane hgap="10" vgap="10">

        <Button onAction="#onNumClick" prefHeight="25.0" prefWidth="60.0" text="7" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <Button onAction="#onNumClick" prefWidth="60" text="8" GridPane.columnIndex="1" GridPane.rowIndex="0" />
        <Button onAction="#onNumClick" prefWidth="60" text="9" GridPane.columnIndex="2" GridPane.rowIndex="0" />
        <Button onAction="#onOpClick" prefWidth="60" style="-fx-background-color: orange;" text="/" GridPane.columnIndex="3" GridPane.rowIndex="0" />

        <Button onAction="#onNumClick" prefWidth="60" text="4" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <Button onAction="#onNumClick" prefWidth="60" text="5" GridPane.columnIndex="1" GridPane.rowIndex="1" />
        <Button onAction="#onNumClick" prefWidth="60" text="6" GridPane.columnIndex="2" GridPane.rowIndex="1" />
        <Button onAction="#onOpClick" prefWidth="60" style="-fx-background-color: orange;" text="*" GridPane.columnIndex="3" GridPane.rowIndex="1" />

        <Button onAction="#onNumClick" prefWidth="60" text="1" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <Button onAction="#onNumClick" prefWidth="60" text="2" GridPane.columnIndex="1" GridPane.rowIndex="2" />
        <Button onAction="#onNumClick" prefWidth="60" text="3" GridPane.columnIndex="2" GridPane.rowIndex="2" />
        <Button onAction="#onOpClick" prefWidth="60" style="-fx-background-color: orange;" text="-" GridPane.columnIndex="3" GridPane.rowIndex="2" />

        <Button onAction="#onNumClick" prefWidth="60" text="0" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <Button onAction="#onSqrtClick" prefWidth="60" text="√" GridPane.columnIndex="1" GridPane.rowIndex="3" />
        <Button onAction="#onFactClick" prefWidth="60" text="n!" GridPane.columnIndex="2" GridPane.rowIndex="3" />
        <Button onAction="#onOpClick" prefWidth="60" style="-fx-background-color: orange;" text="+" GridPane.columnIndex="3" GridPane.rowIndex="3" />

        <Button onAction="#onOpClick" prefWidth="60" text="^" GridPane.columnIndex="0" GridPane.rowIndex="4" />
        <Button onAction="#onClearClick" prefWidth="60" style="-fx-background-color: red; -fx-text-fill: white;" text="C" GridPane.columnIndex="1" GridPane.rowIndex="4" />
        <Button onAction="#onEqualsClick" prefWidth="130" style="-fx-background-color: green; -fx-text-fill: white;" text="=" GridPane.columnIndex="2" GridPane.columnSpan="2" GridPane.rowIndex="4" />
        
        <Button onAction="#onMemClick" prefWidth="60" style="-fx-font-size: 10;" text="MS" GridPane.columnIndex="0" GridPane.rowIndex="5" />
        <Button onAction="#onMemClick" prefWidth="60" style="-fx-font-size: 10;" text="MR" GridPane.columnIndex="1" GridPane.rowIndex="5" />
        <Button onAction="#onMemClick" prefWidth="60" style="-fx-font-size: 10;" text="M+" GridPane.columnIndex="2" GridPane.rowIndex="5" />
        <Button onAction="#onMemClick" prefWidth="60" style="-fx-font-size: 10;" text="MC" GridPane.columnIndex="3" GridPane.rowIndex="5" />
      <columnConstraints>
         <ColumnConstraints />
         <ColumnConstraints />
         <ColumnConstraints />
         <ColumnConstraints />
      </columnConstraints>
      <rowConstraints>
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
      </rowConstraints>
    </GridPane>
</VBox>
